# Telegram
BOT_TOKEN=

# Only your Telegram user id may use the bot (personal tutor, not public)
ADMIN_TELEGRAM_ID=

# Claude API
ANTHROPIC_API_KEY=
ANTHROPIC_CONVERSATION_MODEL=claude-sonnet-5
ANTHROPIC_EVALUATION_MODEL=claude-sonnet-5

# STT - Groq (primary, free tier: 2000 req/day)
GROQ_API_KEY=
STT_PROVIDER=groq
# STT_PROVIDER=local  # requires the local-voice optional dependency group

# TTS
TTS_PROVIDER=edge
EDGE_TTS_VOICE_EN=en-US-AriaNeural
EDGE_TTS_VOICE_RU=ru-RU-SvetlanaNeural
# TTS_PROVIDER=piper  # fully offline fallback

# Database
DATABASE_URL=postgresql+asyncpg://tutor:tutor@localhost:5432/tutor

# Redis
REDIS_URL=redis://localhost:6379/0

# App
LOG_LEVEL=INFO
TIMEZONE=Asia/Tashkent
